# Copy this file to .env.local and fill in values (never commit .env.local).
# Used by scripts/Start-TrackHire.ps1 for DB seed + Tomcat 9 JDBC env.

# Absolute path to Apache Tomcat 9 home (must contain bin\startup.bat)
CATALINA_HOME=C:\\Apache\\apache-tomcat-9.0.xx

# MySQL client credentials (same server you use from MySQL Workbench)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
# Leave empty to use "mysql" from PATH (typical MySQL Server install).
#MYSQL_EXECUTABLE=C:\\Program Files\\MySQL\\MySQL Server 8.0\\bin\\mysql.exe

# JDBC + seed user (often root for local dev)
DB_USER=root
DB_PASSWORD=your_mysql_password_here

# Optional JDBC URL override (ampersands must stay on one line; use useSSL=false if local MySQL rejects SSL)
DB_URL=jdbc:mysql://localhost:3306/trackhire?useSSL=true&serverTimezone=UTC

# Optional: set to 1 so scripts/Start-TrackHire.ps1 skips Maven tests without passing -SkipTests
# TRACKHIRE_SKIP_MVN_TESTS=1
